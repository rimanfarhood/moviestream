@model IEnumerable<MovieStream.Models.Movie>

<h1>Movie Management</h1>

<p>
    <a asp-action="Create">Add New Movie</a>
</p>

<form asp-action="Index" method="get">
    <input type="text"
           name="searchString"
           placeholder="Search by title" />

    <button type="submit">
        Search
    </button>
</form>

<hr />

<table class="table">

    <thead>
        <tr>
            <th>Poster</th>
            <th>Title</th>
            <th>Genre</th>
            <th>Rating</th>
            <th>Release Year</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var movie in Model)
        {
            <tr>

                <td>
                    <img src="@movie.PosterUrl"
                         alt="@movie.Title"
                         width="75" />
                </td>

                <td>@movie.Title</td>

                <td>@movie.Genere</td>

                <td>@movie.Rating</td>

                <td>@movie.ReleaseYear</td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@movie.Id">
                        Details
                    </a>

                    |

                    <a asp-action="Edit"
                       asp-route-id="@movie.Id">
                        Edit
                    </a>

                    |

                    <a asp-action="Delete"
                       asp-route-id="@movie.Id">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>
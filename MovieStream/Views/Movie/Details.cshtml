@model MovieStream.Models.Movie

<div class="container mt-5">

    <div class="card shadow-lg">

        <div class="row g-0">

            <div class="col-md-4">

                <img src="@Model.PosterUrl"
                     class="img-fluid rounded-start"
                     alt="@Model.Title" />

            </div>

            <div class="col-md-8">

                <div class="card-body">

                    <h1 class="card-title">
                        @Model.Title
                    </h1>

                    <hr />

                    <p>
                        <strong>Genre:</strong>
                        @Model.Genere
                    </p>

                    <p>
                        <strong>Release Year:</strong>
                        @Model.ReleaseYear
                    </p>

                    <p>
                        <strong>Rating:</strong>
                        ⭐ @Model.Rating / 10
                    </p>

                    <p>
                        <strong>Duration:</strong>
                        @Model.Duration min
                    </p>

                    <hr />

                    <h4>Description</h4>

                    <p>
                        @Model.Description
                    </p>

                    <div class="mt-4">

                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-danger">
                            Delete
                        </a>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Back to Movies
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>